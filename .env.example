# Copy to .env.local (never commit .env.local)

# Google AI Studio — free tier: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional — override the default model (e.g. gemini-2.5-flash, gemini-2.0-flash-lite)
# VITE_GEMINI_MODEL=gemini-2.5-flash

# Private code to unlock mock interview (only you should know this)
VITE_INTERVIEW_ACCESS_CODE=your_secret_code_here
